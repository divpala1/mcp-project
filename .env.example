# Copy this to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is committed so teammates know the shape.
#
# This file is the contract between `pydantic-settings` (which validates on
# startup) and whoever runs the agent / server. Missing required vars should
# fail loudly, not silently default to wrong values.


# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider is chosen here; the agent code never imports a specific provider.
# See `agent/llm.py` (stage 4) for the factory that reads these two vars.
LLM_PROVIDER=groq                          # groq | anthropic | ollama
LLM_MODEL=llama-3.3-70b-versatile          # good tool calling, fast on Groq

# Fill in whichever provider you chose above. The others can stay blank.
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434


# ── MCP servers (the agent is the CLIENT — these are URLs it connects to) ────
# These provide the *default* server set. `run_agent()` callers can override
# by passing `mcp_servers=...` directly — production multi-tenant hosts that
# resolve servers per user/org typically do that and ignore these env vars.
RAG_MCP_URL=http://127.0.0.1:8000/mcp/sse
NOTES_MCP_URL=http://127.0.0.1:8001/mcp/sse


# ── CLI-only convenience (NOT used in production) ────────────────────────────
# Bearer token used by `python -m agent.main "..."` to authenticate against
# the MCP servers. Must match one of the keys in AUTH_TOKENS_JSON below.
#
# In production this var doesn't exist: the FastAPI endpoint at
# `agent/api.py` forwards the caller's `Authorization` header through to
# the agent — end-to-end identity preserves Qdrant org-scoping for
# multi-user deployments. See agent/api.py for the forwarding logic.
AGENT_AUTH_TOKEN=tok_alice


# ── MCP SERVER side: bearer-token -> identity map ────────────────────────────
# CLAUDE.md C1: MCP has no user concept — auth is a transport-layer concern.
# In dev, a static JSON map is sufficient. In prod, this becomes OAuth 2.1.
# The server resolves the incoming token to {user_id, org_id} and stores it
# in a ContextVar; every Qdrant query filters on org_id.
AUTH_TOKENS_JSON={"tok_alice":{"user_id":"alice","org_id":"acme"},"tok_bob":{"user_id":"bob","org_id":"globex"}


# ── Qdrant ───────────────────────────────────────────────────────────────────
# Local Docker instance — see docker-compose.yml.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents


# ── Embeddings ───────────────────────────────────────────────────────────────
# Loaded once on first use (singleton in mcp_server/core/embeddings.py).
# all-MiniLM-L6-v2 is the sentence-transformers default — 384-dim, local, no key.
EMBEDDING_MODEL=all-MiniLM-L6-v2


# ── Observability (optional) ─────────────────────────────────────────────────
# If LANGSMITH_API_KEY is unset, tracing is silently skipped — the agent
# still runs. See `agent/observability.py` (stage 4).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mcp-agent-learning
