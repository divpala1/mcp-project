# Copy this to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is committed so teammates know the shape.
#
# This file is the contract between `pydantic-settings` (which validates on
# startup) and whoever runs the agent / server. Missing required vars should
# fail loudly, not silently default to wrong values.


# ── LLM ──────────────────────────────────────────────────────────────────────
# Provider is chosen here; the agent code never imports a specific provider.
# See `agent/llm.py` (stage 4) for the factory that reads these two vars.
LLM_PROVIDER=groq                          # groq | anthropic | ollama | openai
LLM_MODEL=llama-3.3-70b-versatile          # good tool calling, fast on Groq

# Fill in whichever provider you chose above. The others can stay blank.
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── LLM generation defaults (overridable per-request) ───────────────────────
# Defaults applied when a request doesn't supply a value. Per-request callers
# (HTTP body field `model_params`, or `run_agent(model_params=...)` in code)
# beat these. Leaving any of these *unset* (commented out, not set to empty)
# omits them entirely, so the provider applies its own default. See
# agent/llm.py for the full resolution path.
DEFAULT_TEMPERATURE=0.0
# DEFAULT_TOP_P=0.95
# DEFAULT_MAX_TOKENS=4096

# OpenAI + any OpenAI-compatible provider.
# Leave OPENAI_BASE_URL blank to hit the real OpenAI API.
# Override it to reach any compatible endpoint — no code changes needed:
#   Together AI:  https://api.together.xyz/v1
#   Fireworks:    https://api.fireworks.ai/inference/v1
#   LM Studio:    http://localhost:1234/v1
#   Cerebras:     https://api.cerebras.ai/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=


# ── MCP servers (the agent is the CLIENT — these are URLs it connects to) ────
# These provide the *default* server set. `run_agent()` callers can override
# by passing `mcp_servers=...` directly — production multi-tenant hosts that
# resolve servers per user/org typically do that and ignore these env vars.
#
# To add a new MCP server: add its env vars here, add corresponding fields
# to AgentConfig in agent/config.py, and wire it into default_mcp_servers().
# GitHub uses a static service credential (GITHUB_PAT); per-request user
# bearer (AGENT_AUTH_TOKEN) is the default for user-scoped servers.
# See McpServerSpec docstring in agent/config.py for the auth-model split.


# ── GitHub MCP (https://github.com/github/github-mcp-server) ─────────────────
# Hosted endpoint. Streamable HTTP transport (the spec's newer replacement
# for SSE — same shape, different wire protocol). Auth is a GitHub PAT sent
# as `Authorization: Bearer <pat>`; OAuth is only wired up for first-party
# clients like VS Code.
#
# Leaving GITHUB_PAT empty omits the github server from the default set
# entirely, so the agent runs fine without it.
#
# Create a fine-grained PAT at https://github.com/settings/personal-access-tokens
# scoped to the repos you want the agent to touch. Read-only for safety while
# learning; widen scopes once you trust the prompts.
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_PAT=


# ── LangChain Docs MCP (https://docs.langchain.com/use-these-docs) ───────────
# Public hosted MCP server — no auth required. Streamable HTTP transport.
# Exposes real-time search over LangChain, LangGraph, and LangSmith docs.
# The default URL is the canonical one; only override if LangChain moves it.
# Included in the default server set whenever this var is non-empty.
LANGCHAIN_DOCS_MCP_URL=https://docs.langchain.com/mcp


# ── CLI-only convenience (NOT used in production) ────────────────────────────
# Bearer token used by `python -m agent.main "..."` to authenticate against
# the MCP servers. Must match one of the keys in AUTH_TOKENS_JSON below.
#
# In production this var doesn't exist: the FastAPI endpoint at
# `agent/api.py` forwards the caller's `Authorization` header through to
# the agent — end-to-end identity preserves Qdrant org-scoping for
# multi-user deployments. See agent/api.py for the forwarding logic.
AGENT_AUTH_TOKEN=tok_alice


# ── MCP SERVER side: bearer-token -> identity map ────────────────────────────
# CLAUDE.md C1: MCP has no user concept — auth is a transport-layer concern.
# In dev, a static JSON map is sufficient. In prod, this becomes OAuth 2.1.
# The server resolves the incoming token to {user_id, org_id} and stores it
# in a ContextVar; every Qdrant query filters on org_id.
AUTH_TOKENS_JSON={"tok_alice":{"user_id":"alice","org_id":"acme"},"tok_bob":{"user_id":"bob","org_id":"globex"}


# ── Qdrant ───────────────────────────────────────────────────────────────────
# Local Docker instance — see docker-compose.yml.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents


# ── Embeddings ───────────────────────────────────────────────────────────────
# Loaded once on first use (singleton in mcp_server/core/embeddings.py).
# all-MiniLM-L6-v2 is the sentence-transformers default — 384-dim, local, no key.
EMBEDDING_MODEL=all-MiniLM-L6-v2


# ── Observability (optional) ─────────────────────────────────────────────────
# LangSmith and Langfuse can both be enabled at the same time — each is
# independently opt-in. If a key is unset its backend is silently skipped.
# See `agent/observability.py`.

# LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mcp-agent-learning

# Langfuse (https://langfuse.com — free cloud tier, or self-hosted)
# Get keys at https://cloud.langfuse.com → Settings → API Keys.
# Override LANGFUSE_HOST to your own endpoint for self-hosted deployments.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
