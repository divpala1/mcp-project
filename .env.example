# Copy this to `.env` and fill in real values.
# `.env` is git-ignored; `.env.example` is committed so teammates know the shape.
#
# This file is the contract between `pydantic-settings` (which validates on
# startup) and whoever runs the agent / server. Missing required vars should
# fail loudly, not silently default to wrong values.


# в”Ђв”Ђ LLM в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Provider is chosen here; the agent code never imports a specific provider.
# See `agent/llm.py` (stage 4) for the factory that reads these two vars.
LLM_PROVIDER=groq                          # groq | anthropic | ollama
LLM_MODEL=llama-3.3-70b-versatile          # good tool calling, fast on Groq

# Fill in whichever provider you chose above. The others can stay blank.
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434


# в”Ђв”Ђ MCP servers (the agent is the CLIENT вЂ” these are URLs it connects to) в”Ђв”Ђв”Ђв”Ђ
# These provide the *default* server set. `run_agent()` callers can override
# by passing `mcp_servers=...` directly вЂ” production multi-tenant hosts that
# resolve servers per user/org typically do that and ignore these env vars.
#
# rag/notes use the per-request user bearer (AGENT_AUTH_TOKEN below) so each
# user's calls land scoped to their org. github uses a static service
# credential (GITHUB_PAT) вЂ” see McpServerSpec docstring for why these two
# auth models live side-by-side.
RAG_MCP_URL=http://127.0.0.1:8000/mcp/sse
NOTES_MCP_URL=http://127.0.0.1:8001/mcp/sse


# в”Ђв”Ђ GitHub MCP (https://github.com/github/github-mcp-server) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Hosted endpoint. Streamable HTTP transport (the spec's newer replacement
# for SSE вЂ” same shape, different wire protocol). Auth is a GitHub PAT sent
# as `Authorization: Bearer <pat>`; OAuth is only wired up for first-party
# clients like VS Code.
#
# Leaving GITHUB_PAT empty omits the github server from the default set
# entirely, so the agent runs fine without it.
#
# Create a fine-grained PAT at https://github.com/settings/personal-access-tokens
# scoped to the repos you want the agent to touch. Read-only for safety while
# learning; widen scopes once you trust the prompts.
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
GITHUB_PAT=


# в”Ђв”Ђ CLI-only convenience (NOT used in production) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Bearer token used by `python -m agent.main "..."` to authenticate against
# the MCP servers. Must match one of the keys in AUTH_TOKENS_JSON below.
#
# In production this var doesn't exist: the FastAPI endpoint at
# `agent/api.py` forwards the caller's `Authorization` header through to
# the agent вЂ” end-to-end identity preserves Qdrant org-scoping for
# multi-user deployments. See agent/api.py for the forwarding logic.
AGENT_AUTH_TOKEN=tok_alice


# в”Ђв”Ђ MCP SERVER side: bearer-token -> identity map в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# CLAUDE.md C1: MCP has no user concept вЂ” auth is a transport-layer concern.
# In dev, a static JSON map is sufficient. In prod, this becomes OAuth 2.1.
# The server resolves the incoming token to {user_id, org_id} and stores it
# in a ContextVar; every Qdrant query filters on org_id.
AUTH_TOKENS_JSON={"tok_alice":{"user_id":"alice","org_id":"acme"},"tok_bob":{"user_id":"bob","org_id":"globex"}


# в”Ђв”Ђ Qdrant в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Local Docker instance вЂ” see docker-compose.yml.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents


# в”Ђв”Ђ Embeddings в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Loaded once on first use (singleton in mcp_server/core/embeddings.py).
# all-MiniLM-L6-v2 is the sentence-transformers default вЂ” 384-dim, local, no key.
EMBEDDING_MODEL=all-MiniLM-L6-v2


# в”Ђв”Ђ Observability (optional) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# If LANGSMITH_API_KEY is unset, tracing is silently skipped вЂ” the agent
# still runs. See `agent/observability.py` (stage 4).
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=mcp-agent-learning
